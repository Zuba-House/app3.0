{
  "name": "zuba-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npx expo start",
    "start:lan": "npx expo start --lan --clear",
    "start:tunnel": "npx expo start --tunnel --clear",
    "start:iphone": "powershell -ExecutionPolicy Bypass -File ./start-expo-iphone.ps1",
    "android": "npx expo run:android",
    "android:auto": "powershell -ExecutionPolicy Bypass -File ./AUTO_RUN_EMULATOR.ps1",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "test": "jest",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@reduxjs/toolkit": "^2.0.1",
    "expo": "~54.0.0",
    "expo-constants": "^55.0.7",
    "expo-device": "~6.0.2",
    "expo-image": "~3.0.11",
    "expo-notifications": "^0.32.16",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "^15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.11.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.5.1",
    "react-redux": "^9.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@tsconfig/react-native": "^3.0.8",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
