{
  "expo": {
    "name": "Zuba",
    "slug": "zuba-mobile",
    "version": "1.0.0",
    "scheme": "zuba",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e5e2db"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zubahouse.customer",
      "googleServicesFile": "./GoogleService-Info.plist",
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#e5e2db"
      },
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.zubahouse.customer",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b2735"
      },
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#e5e2db"
      }
    },
    "extra": {
      "apiUrl": "https://zuba-api.onrender.com",
      "eas": {
        "projectId": "zuba-house-019"
      },
      "googleClientId": "473177050132-tbjv9abc8bt4fep3eq7grm0faqa3e5dt.apps.googleusercontent.com"
    },
    "packagerOpts": {
      "config": "metro.config.js"
    },
  }
}

